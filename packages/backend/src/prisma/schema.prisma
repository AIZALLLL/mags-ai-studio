generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// PHASES 1-7: Previous models (User, Chat, Agent, Repository, App, etc.)
// ============================================================================
// (All existing models from Phases 1-7 remain unchanged)

model User {
  id            String        @id @default(cuid())
  email         String        @unique @db.VarChar(255)
  username      String        @unique @db.VarChar(50)
  password      String        @db.Text
  firstName     String?       @db.VarChar(100)
  lastName      String?       @db.VarChar(100)
  avatar        String?       @db.Text
  bio           String?       @db.Text
  phone         String?       @db.VarChar(20)
  emailVerified Boolean       @default(false)
  isActive      Boolean       @default(true)
  isSuspended   Boolean       @default(false) // Security: account suspension
  suspendedUntil DateTime?    // Security: temporary suspension until
  failedLoginAttempts Int     @default(0) // Security: brute force tracking
  lastFailedLoginAt DateTime? // Security: last failed login time
  lastLoginAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations - Phases 3-7
  userRoles      UserRole[]    @relation("UserRoles")
  sessions       Session[]     @relation("UserSessions")
  chats          Chat[]        @relation("UserChats")
  agents         Agent[]       @relation("UserAgents")
  repositories   Repository[]  @relation("UserRepositories")
  apps           GeneratedApp[] @relation("UserApps")

  // Relations - Phase 8
  securityEvents SecurityEvent[] @relation("UserSecurityEvents")
  auditLogs      AuditLog[]    @relation("UserAuditLogs")
  threats        ThreatDetection[] @relation("UserThreats")
  sessionLogs    UserSessionLog[] @relation("UserSessionLogs")
  alerts         SecurityAlert[] @relation("UserAlerts")
  anomalyScores  AnomalyScore[] @relation("UserAnomalyScores")
  complianceLogs ComplianceLog[] @relation("UserComplianceLogs")
  deletionRequests DataDeletionRequest[] @relation("UserDeletionRequests")

  @@index([email])
  @@index([username])
  @@index([isSuspended])
  @@map("users")
}

// (Previous models from Phases 3-7)

// ============================================================================
// PHASE 8: Security Center System (NEW)
// ============================================================================

model SecurityEvent {
  id            String   @id @default(cuid())
  userId        String
  
  // Event classification
  eventType     String   @db.VarChar(100) // "login", "logout", "failed_auth", "api_call", "admin_action", "data_modification", "anomaly"
  category      String   @db.VarChar(50) // "auth", "api", "admin", "system", "data"
  
  // Event details
  description   String   @db.Text
  
  // Context
  ipAddress     String?  @db.VarChar(45) // IPv4 or IPv6
  userAgent     String?  @db.Text
  deviceId      String?  @db.VarChar(100)
  
  // Metadata
  metadata      Json?
  
  // Risk assessment
  initialRiskScore Int   @default(0) // 0-100
  
  // Storage control
  isAuditable   Boolean  @default(true) // Should be included in audit logs
  
  createdAt     DateTime @default(now())

  // Relations
  user          User     @relation("UserSecurityEvents", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType])
  @@index([category])
  @@index([createdAt])
  @@map("security_events")
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String
  
  // Audit details
  action        String   @db.VarChar(100) // "user_login", "file_created", "user_deleted", etc.
  resourceType  String   @db.VarChar(50) // "user", "file", "settings", "app", etc.
  resourceId    String?  @db.VarChar(100) // What was affected
  
  // Change tracking
  changesBefore Json?    // Previous state
  changesAfter  Json?    // New state
  
  // Context
  ipAddress     String?  @db.VarChar(45)
  userAgent     String?  @db.Text
  
  // Immutability
  previousHash  String?  @db.VarChar(64) // Hash of previous log for chain
  logHash       String   @db.VarChar(64) // Hash of this log (immutability proof)
  
  // Compliance
  complianceRelevant Boolean @default(false) // GDPR, etc.
  
  createdAt     DateTime @default(now())

  // Relations
  user          User     @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([resourceType])
  @@index([createdAt])
  @@map("audit_logs")
}

model ThreatDetection {
  id            String   @id @default(cuid())
  userId        String
  
  // Threat classification
  threatType    String   @db.VarChar(100) // "brute_force", "suspicious_login", "rate_anomaly", "data_access_anomaly"
  severity      String   @db.VarChar(20) @default("low") // "critical", "high", "medium", "low"
  
  // Detection details
  description   String   @db.Text
  indicators    String[] @default([]) // List of indicators detected
  
  // Scoring
  confidenceScore Float  @default(0.0) // 0.0-1.0: how confident we are
  riskScore      Int     @default(0) // 0-100: overall risk
  
  // Action taken
  actionTaken   String?  @db.VarChar(100) // "blocked", "alerted", "throttled", null
  
  // Status
  status        String   @db.VarChar(50) @default("detected") // "detected", "investigating", "resolved", "false_positive"
  
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?

  // Relations
  user          User     @relation("UserThreats", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([threatType])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
  @@map("threat_detections")
}

model SecurityRule {
  id            String   @id @default(cuid())
  
  // Rule definition
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  
  // Rule logic (JSON-based condition)
  condition     Json     // { "eventType": "login", "failedCount": { "gt": 5 }, "timeWindow": 300 }
  
  // Actions to take (array)
  actions       Json     // [{ "type": "block", "duration": 3600 }, { "type": "alert" }]
  
  // Configuration
  priority      Int      @default(50) // 1-100: higher = more important
  isEnabled     Boolean  @default(true)
  isSystem      Boolean  @default(false) // System rules can't be deleted
  
  // Usage tracking
  triggeredCount Int     @default(0)
  lastTriggeredAt DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  executions    RuleExecution[] @relation("RuleExecutions")

  @@index([priority])
  @@index([isEnabled])
  @@map("security_rules")
}

model RuleExecution {
  id            String   @id @default(cuid())
  ruleId        String
  
  // Execution context
  eventId       String?  // What triggered this
  result        String   @db.VarChar(50) // "matched", "not_matched", "error"
  
  // Actions executed
  actionsExecuted Json? // What actions were run
  
  createdAt     DateTime @default(now())

  // Relations
  rule          SecurityRule @relation("RuleExecutions", fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([result])
  @@map("rule_executions")
}

model UserSessionLog {
  id            String   @id @default(cuid())
  userId        String
  sessionId     String   // Reference to Session (Phase 3)
  
  // Session details
  ipAddress     String   @db.VarChar(45)
  deviceId      String?  @db.VarChar(100)
  deviceName    String?  @db.VarChar(255)
  
  // Geolocation (inferred)
  country       String?  @db.VarChar(2)
  city          String?  @db.VarChar(100)
  
  // Behavioral data
  loginTime     DateTime
  logoutTime    DateTime?
  isActive      Boolean  @default(true)
  
  // Anomaly detection
  isAnomalous   Boolean  @default(false) // Unusual login detected
  anomalyReasons String[] @default([]) // ["new_location", "new_device"]
  
  // Termination tracking
  wasTerminated Boolean  @default(false)
  terminationReason String? @db.VarChar(100) // "admin", "suspicious", "timeout"
  
  createdAt     DateTime @default(now())

  // Relations
  user          User     @relation("UserSessionLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@index([isActive])
  @@index([isAnomalous])
  @@map("user_session_logs")
}

model SecurityAlert {
  id            String   @id @default(cuid())
  userId        String
  
  // Alert information
  title         String   @db.VarChar(255)
  description   String   @db.Text
  severity      String   @db.VarChar(20) // "critical", "high", "medium", "low"
  
  // Alert type
  alertType     String   @db.VarChar(100) // "suspicious_login", "data_breach_attempt", etc.
  
  // Status
  status        String   @db.VarChar(50) @default("open") // "open", "acknowledged", "resolved"
  acknowledgedAt DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user          User     @relation("UserAlerts", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([severity])
  @@index([status])
  @@map("security_alerts")
}

model AnomalyScore {
  id            String   @id @default(cuid())
  userId        String
  
  // Score details
  score         Int      @default(0) // 0-100: risk level
  
  // Factors contributing to score
  factors       Json     // { "recent_login_failures": 5, "unusual_time": true, ... }
  
  // Baseline for user
  userBaseline  Json?    // User's normal behavior patterns
  
  // Temporal
  calculatedAt  DateTime @default(now())
  expiresAt     DateTime // When this score becomes stale

  // Relations
  user          User     @relation("UserAnomalyScores", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([score])
  @@index([calculatedAt])
  @@map("anomaly_scores")
}

model ComplianceLog {
  id            String   @id @default(cuid())
  userId        String
  
  // Compliance event
  eventType     String   @db.VarChar(100) // "gdpr_export_requested", "data_deletion_requested", "consent_given"
  regulation    String   @db.VarChar(50) // "gdpr", "ccpa", etc.
  
  // Details
  description   String   @db.Text
  metadata      Json?
  
  // Status
  status        String   @db.VarChar(50) @default("pending") // "pending", "completed", "failed"
  completedAt   DateTime?
  
  createdAt     DateTime @default(now())

  // Relations
  user          User     @relation("UserComplianceLogs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventType])
  @@index([regulation])
  @@map("compliance_logs")
}

model DataDeletionRequest {
  id            String   @id @default(cuid())
  userId        String
  
  // Deletion details
  reason        String   @db.Text
  requestedBy   String   @db.VarChar(100) // "user", "admin"
  
  // Status
  status        String   @db.VarChar(50) @default("pending") // "pending", "approved", "completed", "cancelled"
  approvedBy    String?  @db.VarChar(100) // Admin who approved
  approvedAt    DateTime?
  
  // Execution
  executedAt    DateTime?
  deletedDataHash String? @db.VarChar(64) // Hash of deleted data for audit
  
  createdAt     DateTime @default(now())

  // Relations
  user          User     @relation("UserDeletionRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("data_deletion_requests")
}